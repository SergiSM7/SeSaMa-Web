---
// En la home los enlaces son anclas con scroll suave (#seccion);
// fuera de la home (ej. /cookies) apuntan a /#seccion para volver al inicio.
const path = Astro.url.pathname
const home = path === "/" || path === ""
const base = home ? "" : "/"
---
<nav id="nav">
  <a href={home ? "#hero" : "/"} class="brand" data-magnet><span class="dot"></span>Sergi Sagrera</a>
  <div class="nav-links" id="navlinks">
    <a href={`${base}#about`} data-i18n="nav.about">Sobre mí</a>
    <a href={`${base}#experience`} data-i18n="nav.experience">Experiencia</a>
    <a href={`${base}#projects`} data-i18n="nav.projects">Proyectos</a>
    <a href={`${base}#stack`} data-i18n="nav.stack">Stack</a>
    <a href={`${base}#contact`} data-i18n="nav.contact">Contacto</a>
  </div>
  <div class="nav-tools">
    <div class="lang" id="lang">
      <button data-lang="es" class="on">ES</button>
      <button data-lang="ca">CA</button>
      <button data-lang="en">EN</button>
    </div>
    <button class="toggle" id="themeBtn" aria-label="Cambiar tema"></button>
    <button class="burger" id="burger" aria-label="Menú">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="16" x2="21" y2="16"/></svg>
    </button>
  </div>
</nav>
