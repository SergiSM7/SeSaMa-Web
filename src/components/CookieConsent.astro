---
---
<div id="cookie-banner" class="ck" hidden aria-live="polite" role="dialog" aria-label="Cookies">
  <div class="ck-card">
    <div class="ck-main">
      <h3 class="ck-title" data-i18n="cookies.title">Cookies</h3>
      <p class="ck-text" data-i18n="cookies.text"></p>
      <a class="ck-policy" href="/cookies" data-i18n="cookies.policy">Política de cookies</a>
    </div>

    <div class="ck-prefs" id="ck-prefs" hidden>
      <div class="ck-row">
        <div>
          <span class="ck-row-t" data-i18n="cookies.necessary">Necesarias</span>
          <span class="ck-row-d" data-i18n="cookies.necessaryDesc"></span>
        </div>
        <span class="ck-always" data-i18n="cookies.always">Siempre activas</span>
      </div>
      <label class="ck-row">
        <div>
          <span class="ck-row-t" data-i18n="cookies.analytics">Analítica</span>
          <span class="ck-row-d" data-i18n="cookies.analyticsDesc"></span>
        </div>
        <input type="checkbox" id="ck-analytics" class="ck-switch" />
      </label>
    </div>

    <div class="ck-actions">
      <button class="ck-btn ck-ghost" id="ck-reject" data-i18n="cookies.reject">Rechazar</button>
      <button class="ck-btn ck-ghost" id="ck-config" data-i18n="cookies.configure">Configurar</button>
      <button class="ck-btn ck-primary" id="ck-accept" data-i18n="cookies.accept">Aceptar</button>
      <button class="ck-btn ck-primary" id="ck-save" data-i18n="cookies.save" hidden>Guardar preferencias</button>
    </div>
  </div>
</div>
