---
---
<section id="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow" id="heroGlow"></div>
  <div class="wrap hero-inner">
    <div class="hero-top">
      <span class="status"><span class="live"></span><span data-i18n="hero.role">Full-stack Developer</span></span>
      <span class="hero-role" data-i18n="hero.status">Barcelona · +5 años</span>
    </div>
    <h1 class="hero">
      <span class="linewrap"><span class="line">Sergi</span></span>
      <span class="linewrap"><span class="line"><em>Sagrera<span class="cursor-bar"></span></em></span></span>
    </h1>
    <div class="hero-bottom">
      <p class="hero-tagline" data-i18n="hero.tagline">Desarrollador full-stack de Barcelona. Creo aplicaciones web a medida y optimizo tiendas online, del front-end a la lógica interna.</p>
      <div class="hero-ctas">
        <a href="#projects" class="btn btn-primary" data-magnet><span data-i18n="hero.ctaPrimary">Ver proyectos</span><span class="arr">→</span></a>
        <a href="#about" class="btn btn-ghost" data-magnet><span data-i18n="hero.ctaSecondary">Sobre mí</span></a>
      </div>
    </div>
  </div>
  <div class="scrollcue"><span data-i18n="hero.scroll">Desliza</span><span class="bar"></span></div>
</section>

<!-- MARQUEE -->
<div class="marquee"><div class="marquee-track" id="marquee"></div></div>
