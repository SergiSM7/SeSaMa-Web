---
import CookieConsent from "../components/CookieConsent.astro"

interface Props {
  title: string
  description: string
}

const { description, title } = Astro.props
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    {/* No-flash theme: saved pref → system pref → dark, applied before first paint */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("ss-theme");
          var sysDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          var t = saved || (sysDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
      })();
    </script>

    {/* Consent Mode v2 — debe ejecutarse ANTES de gtag.js. Por defecto
        denegado → sin cookies hasta aceptar. Caduca a los 12 meses (AEPD). */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "granted",
        security_storage: "granted",
        wait_for_update: 500
      });
      gtag("set", "url_passthrough", true);
      gtag("set", "ads_data_redaction", true);
      window.__gaValidConsent = function () {
        try {
          var s = JSON.parse(localStorage.getItem("ss-consent") || "null");
          if (!s || !s.ts || (Date.now() - s.ts) > 365 * 24 * 60 * 60 * 1000) return null;
          return s;
        } catch (e) { return null; }
      };
      var __prev = window.__gaValidConsent();
      if (__prev && __prev.analytics) {
        gtag("consent", "update", { analytics_storage: "granted" });
      }
    </script>
    {/* Google tag (gtag.js) — etiqueta literal para que GA la detecte */}
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-L8E2VFSG2Z"></script>
    <script is:inline>
      gtag("js", new Date());
      gtag("config", "G-L8E2VFSG2Z");
    </script>
  </head>
  <body>
    <div id="progress"></div>
    <div id="cursor"></div>

    <slot />

    <CookieConsent />

    <script>
      import "../scripts/i18n.js"
      import "../scripts/app.js"
    </script>

    <style is:global>
      /* ============================================================
         TOKENS
         ============================================================ */
      :root {
        --accent: #ff3d2e;
        --accent-ink: #fff6f4;
        --font-display: "Space Grotesk", system-ui, sans-serif;
        --font-mono: "Space Mono", ui-monospace, monospace;
        --maxw: 1240px;
        --pad: clamp(20px, 5vw, 72px);
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }
      html[data-theme="dark"] {
        --bg: #0a0a0b;
        --bg-2: #101012;
        --bg-3: #16161a;
        --fg: #f5f5f1;
        --fg-2: #a3a39c;
        --muted: #75756e;
        --line: rgba(255, 255, 255, 0.1);
        --line-2: rgba(255, 255, 255, 0.16);
        --accent-text: #ff5e52;
        --glow: rgba(255, 61, 46, 0.24);
        --card: #0e0e10;
      }
      html[data-theme="light"] {
        --bg: #f3f2ec;
        --bg-2: #fbfaf6;
        --bg-3: #ffffff;
        --fg: #0d0d0c;
        --fg-2: #56564f;
        --muted: #86867d;
        --line: rgba(0, 0, 0, 0.12);
        --line-2: rgba(0, 0, 0, 0.2);
        --accent-text: #d42718;
        --glow: rgba(255, 61, 46, 0.26);
        --card: #ffffff;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-display);
        font-weight: 400;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        transition: background 0.5s var(--ease), color 0.5s var(--ease);
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      ::selection {
        background: var(--accent);
        color: var(--accent-ink);
      }
      .mono {
        font-family: var(--font-mono);
      }

      /* scroll progress */
      #progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent);
        z-index: 200;
        box-shadow: 0 0 12px var(--glow);
      }

      /* custom cursor */
      #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent);
        pointer-events: none;
        z-index: 300;
        transform: translate(-50%, -50%);
        transition: width 0.25s var(--ease), height 0.25s var(--ease), background 0.25s, opacity 0.3s;
        mix-blend-mode: difference;
        opacity: 0;
      }
      #cursor.big {
        width: 54px;
        height: 54px;
        background: transparent;
        border: 1.5px solid var(--accent);
      }
      @media (pointer: fine) {
        #cursor {
          opacity: 1;
        }
        /* hay cursor custom: ocultamos el nativo en dispositivos con ratón */
        * {
          cursor: none !important;
        }
      }
      @media (pointer: coarse) {
        #cursor {
          display: none;
        }
      }

      /* ============================================================
         NAV
         ============================================================ */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px var(--pad);
        transition: padding 0.4s var(--ease), background 0.4s var(--ease), border-color 0.4s;
        border-bottom: 1px solid transparent;
      }
      nav.scrolled {
        padding: 12px var(--pad);
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(16px) saturate(140%);
        -webkit-backdrop-filter: blur(16px) saturate(140%);
        border-bottom: 1px solid var(--line);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 11px;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-size: 17px;
      }
      .brand .dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 14px var(--glow);
        animation: pulse 2.6s var(--ease) infinite;
      }
      @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.35); opacity: 0.65; }
      }
      .nav-links {
        display: flex;
        gap: 30px;
        align-items: center;
      }
      .nav-links a {
        font-size: 14px;
        color: var(--fg-2);
        position: relative;
        transition: color 0.25s;
        letter-spacing: 0.01em;
      }
      .nav-links a::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -5px;
        height: 1.5px;
        width: 0;
        background: var(--accent);
        transition: width 0.3s var(--ease);
      }
      .nav-links a:hover { color: var(--fg); }
      .nav-links a:hover::after { width: 100%; }
      .nav-tools {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .lang {
        display: flex;
        border: 1px solid var(--line);
        border-radius: 999px;
        overflow: hidden;
        font-family: var(--font-mono);
        font-size: 11px;
      }
      .lang button {
        background: none;
        border: 0;
        color: var(--fg-2);
        padding: 6px 9px;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        transition: color 0.2s, background 0.2s;
      }
      .lang button.on {
        background: var(--accent);
        color: var(--accent-ink);
        font-weight: 700;
      }
      .lang button:not(.on):hover { color: var(--fg); }
      .toggle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid var(--line);
        background: transparent;
        color: var(--fg);
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: border-color 0.25s, transform 0.4s var(--ease);
      }
      .toggle:hover {
        border-color: var(--line-2);
        transform: rotate(25deg);
      }
      .toggle svg { width: 17px; height: 17px; }
      .burger { display: none; }

      /* ============================================================
         LAYOUT HELPERS
         ============================================================ */
      section { position: relative; }
      .wrap {
        max-width: var(--maxw);
        margin: 0 auto;
        padding-left: var(--pad);
        padding-right: var(--pad);
      }
      .seclabel {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent-text);
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 26px;
      }
      .seclabel::before {
        content: "";
        width: 34px;
        height: 1px;
        background: var(--accent);
        opacity: 0.6;
      }
      .h2 {
        font-size: clamp(2rem, 5vw, 3.6rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.02;
      }

      /* ============================================================
         HERO
         ============================================================ */
      #hero {
        min-height: 100svh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        padding-top: 90px;
      }
      .hero-grid {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 78%);
        -webkit-mask-image: radial-gradient(circle at 50% 40%, #000 0%, transparent 78%);
        opacity: 0.6;
      }
      .hero-glow {
        position: absolute;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--glow), transparent 65%);
        filter: blur(30px);
        pointer-events: none;
        left: 0;
        top: 0;
        transform: translate(-50%, -50%);
        transition: opacity 0.6s;
        z-index: 0;
      }
      .hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
      }
      .hero-top {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 30px;
        flex-wrap: wrap;
      }
      .status {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 8px 15px;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-2);
        background: color-mix(in srgb, var(--bg-2) 60%, transparent);
      }
      .status .live {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 0 var(--glow);
        animation: live 2s infinite;
      }
      @keyframes live {
        0% { box-shadow: 0 0 0 0 var(--glow); }
        70% { box-shadow: 0 0 0 9px transparent; }
        100% { box-shadow: 0 0 0 0 transparent; }
      }
      .hero-role {
        font-family: var(--font-mono);
        font-size: 13px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--fg-2);
      }
      .hero {
        font-size: clamp(2.9rem, 11.5vw, 9.5rem);
        font-weight: 700;
        line-height: 0.92;
        letter-spacing: -0.045em;
        margin: 6px 0;
      }
      /* overflow visible: el typewriter ya no usa el slide, así no se cortan
         los descendentes (la "g" de Sergi/Sagrera) */
      .hero .linewrap { display: block; overflow: visible; padding-bottom: 0.04em; }
      .hero .line { display: block; }
      .hero em {
        font-style: normal;
        color: var(--accent-text);
        position: relative;
      }
      .hero em .cursor-bar {
        display: inline-block;
        width: 0.06em;
        height: 0.82em;
        background: var(--accent);
        margin-left: 0.06em;
        vertical-align: -0.06em;
        animation: blink 1.05s steps(1) infinite;
      }
      @keyframes blink {
        50% { opacity: 0; }
      }
      .hero-bottom {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 40px;
        margin-top: 46px;
        flex-wrap: wrap;
      }
      @media (prefers-reduced-motion: no-preference) {
        body.loaded .hero .line { animation: lineIn 0.95s var(--ease) backwards; }
        body.loaded .hero .linewrap:nth-child(2) .line { animation-delay: 0.08s; }
        body.loaded .hero .linewrap:nth-child(3) .line { animation-delay: 0.16s; }
        body.loaded .hero-bottom { animation: fadeUp 0.9s var(--ease) 0.5s backwards; }
      }
      @keyframes lineIn {
        from { transform: translateY(105%); }
        to { transform: translateY(0); }
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(22px); }
        to { opacity: 1; transform: none; }
      }
      .hero-tagline {
        max-width: 46ch;
        font-size: clamp(1rem, 1.6vw, 1.22rem);
        color: var(--fg-2);
        line-height: 1.6;
      }
      .hero-ctas {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      /* buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-mono);
        font-size: 13px;
        letter-spacing: 0.02em;
        padding: 15px 24px;
        border-radius: 999px;
        cursor: pointer;
        border: 1px solid var(--line-2);
        background: transparent;
        color: var(--fg);
        transition: transform 0.35s var(--ease), background 0.3s, color 0.3s, border-color 0.3s;
        will-change: transform;
      }
      .btn .arr { transition: transform 0.35s var(--ease); }
      .btn:hover .arr { transform: translateX(4px); }
      .btn-primary {
        background: var(--accent);
        color: var(--accent-ink);
        border-color: var(--accent);
        font-weight: 700;
      }
      .btn-primary:hover { box-shadow: 0 12px 40px -8px var(--glow); }
      .btn-ghost:hover {
        border-color: var(--fg);
        background: color-mix(in srgb, var(--fg) 7%, transparent);
      }

      .scrollcue {
        position: absolute;
        bottom: 26px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        z-index: 2;
      }
      .scrollcue .bar {
        width: 1px;
        height: 36px;
        background: linear-gradient(var(--accent), transparent);
        animation: drop 1.8s var(--ease) infinite;
      }
      @keyframes drop {
        0% { transform: scaleY(0); transform-origin: top; }
        50% { transform: scaleY(1); transform-origin: top; }
        50.1% { transform-origin: bottom; }
        100% { transform: scaleY(0); transform-origin: bottom; }
      }

      /* ============================================================
         MARQUEE
         ============================================================ */
      .marquee {
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: 24px 0;
        overflow: hidden;
        white-space: nowrap;
        margin-top: 10px;
        -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
        mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
      }
      .marquee-track {
        display: inline-flex;
        gap: 0;
        animation: scroll 32s linear infinite;
      }
      .marquee:hover .marquee-track { animation-play-state: paused; }
      .marquee-item {
        font-size: clamp(1.4rem, 3vw, 2.4rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--fg-2);
        display: inline-flex;
        align-items: center;
      }
      .marquee-item::after {
        content: "✦";
        color: var(--accent-text);
        margin: 0 34px;
        font-size: 0.5em;
        vertical-align: middle;
      }
      @keyframes scroll {
        to { transform: translateX(-50%); }
      }

      /* ============================================================
         SECTION PADDING
         ============================================================ */
      .sec { padding: clamp(80px, 12vw, 160px) 0; }

      /* ABOUT */
      .about-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: clamp(40px, 6vw, 90px);
        align-items: start;
      }
      .about-heading {
        font-size: clamp(1.6rem, 3.4vw, 2.7rem);
        font-weight: 500;
        letter-spacing: -0.025em;
        line-height: 1.18;
        margin-bottom: 38px;
        max-width: 20ch;
      }
      .about-heading b { font-weight: 700; }
      .about-text p {
        color: var(--fg-2);
        font-size: 1.02rem;
        line-height: 1.72;
        margin-bottom: 18px;
        max-width: 60ch;
      }
      .about-text p strong { color: var(--fg); font-weight: 600; }
      .about-side {
        display: flex;
        flex-direction: column;
        gap: 30px;
        position: sticky;
        top: 100px;
      }
      .portrait {
        aspect-ratio: 4/5;
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        position: relative;
        display: grid;
        place-items: center;
      }
      .portrait img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(0.15) contrast(1.02);
        transition: transform 0.9s var(--ease), filter 0.6s;
      }
      .portrait:hover img {
        transform: scale(1.04);
        filter: grayscale(0) contrast(1.05);
      }
      .portrait::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 55%, color-mix(in srgb, var(--accent) 26%, transparent));
        mix-blend-mode: multiply;
        opacity: 0.5;
        pointer-events: none;
      }
      .portrait span {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted);
        background: var(--bg);
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid var(--line);
      }
      .stats {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
      }
      .stat {
        padding: 20px 22px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: baseline;
        gap: 16px;
      }
      .stat:last-child { border-bottom: 0; }
      .stat .n {
        font-size: 2.1rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--accent-text);
        min-width: 62px;
      }
      .stat .l { font-size: 0.92rem; color: var(--fg-2); }

      /* EXPERIENCE — tarjetas por empresa */
      .xp-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 22px;
        margin-top: 10px;
        align-items: start;
      }
      /* la tarjeta con varios roles (y la actual) ocupa toda la fila */
      .xp-card:not(.solo), .xp-card.cur { grid-column: 1 / -1; }
      .xp-card {
        position: relative;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--card);
        padding: 28px clamp(22px, 3vw, 36px);
        overflow: hidden;
        transition: border-color 0.4s, transform 0.5s var(--ease), box-shadow 0.5s;
      }
      .xp-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(var(--accent), transparent);
        opacity: 0.3;
        transition: opacity 0.4s;
      }
      .xp-card:hover {
        transform: translateY(-4px);
        border-color: var(--line-2);
        box-shadow: 0 26px 64px -34px rgba(0, 0, 0, 0.6);
      }
      .xp-card:hover::before { opacity: 1; }
      .xp-card.cur {
        border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
        box-shadow: 0 0 0 1px var(--glow);
      }
      .xp-card.cur::before { opacity: 1; }

      .xp-top { display: flex; align-items: center; gap: 16px; margin-bottom: 22px; }
      .xp-mono-badge {
        width: 54px;
        height: 54px;
        flex-shrink: 0;
        border-radius: 13px;
        border: 1px solid var(--line-2);
        display: grid;
        place-items: center;
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 17px;
        letter-spacing: 0.02em;
        color: var(--accent-text);
        background: color-mix(in srgb, var(--accent) 9%, transparent);
        transition: transform 0.4s var(--ease);
      }
      .xp-card:hover .xp-mono-badge { transform: scale(1.06) rotate(-3deg); }
      .xp-company {
        font-size: clamp(1.25rem, 2.4vw, 1.65rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      .xp-span {
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--muted);
        display: block;
        margin-top: 5px;
      }
      .xp-badge {
        margin-left: auto;
        align-self: flex-start;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-ink);
        background: var(--accent);
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 7px;
      }
      .xp-badge .live {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-ink);
        animation: live 2s infinite;
      }

      /* roles como mini-línea de tiempo dentro de la tarjeta */
      .xp-roles {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin-left: 27px;
        padding-left: 26px;
        border-left: 1px solid var(--line);
      }
      .xp-card.solo .xp-roles {
        margin-left: 0;
        padding-left: 0;
        border-left: 0;
      }
      .xp-role { position: relative; padding-bottom: 22px; }
      .xp-role:last-child { padding-bottom: 0; }
      .xp-card:not(.solo) .xp-role::before {
        content: "";
        position: absolute;
        left: -31px;
        top: 8px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--bg-3);
        border: 2px solid var(--line-2);
        transition: border-color 0.3s, transform 0.3s var(--ease);
      }
      .xp-card:not(.solo):hover .xp-role::before { border-color: var(--accent); }
      .xp-role-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 14px;
        flex-wrap: wrap;
      }
      .xp-role-title {
        font-size: 1.08rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .xp-role-period {
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--muted);
        white-space: nowrap;
      }
      .xp-role-desc {
        color: var(--fg-2);
        line-height: 1.62;
        font-size: 0.95rem;
        margin-top: 7px;
        max-width: 72ch;
      }

      /* PROJECTS */
      .proj { display: flex; flex-direction: column; gap: 8px; }
      .proj-item {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: clamp(28px, 5vw, 70px);
        align-items: center;
        padding: clamp(34px, 5vw, 60px) 0;
        border-top: 1px solid var(--line);
      }
      .proj-item:last-child { border-bottom: 1px solid var(--line); }
      .proj-item:nth-child(even) .proj-media { order: 2; }
      /* browser frame */
      .proj-media {
        border-radius: 14px;
        border: 1px solid var(--line);
        background: var(--bg-3);
        position: relative;
        overflow: hidden;
        transition: transform 0.6s var(--ease), border-color 0.4s, box-shadow 0.5s;
        display: flex;
        flex-direction: column;
      }
      .proj-item:hover .proj-media {
        transform: translateY(-6px);
        border-color: var(--line-2);
        box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.5);
      }
      .browser-bar {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 11px 14px;
        background: var(--bg-2);
        border-bottom: 1px solid var(--line);
        flex-shrink: 0;
        position: relative;
        z-index: 3;
      }
      .browser-dots { display: flex; gap: 7px; flex-shrink: 0; }
      .browser-dots span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--line-2);
      }
      .browser-url {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 8px;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 7px;
        padding: 5px 11px;
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--fg-2);
        overflow: hidden;
        white-space: nowrap;
      }
      .browser-url svg { width: 11px; height: 11px; flex-shrink: 0; color: var(--accent-text); }
      .proj-shot {
        position: relative;
        width: 100%;
        aspect-ratio: 16/10;
        overflow: hidden;
        background: repeating-linear-gradient(135deg, var(--bg-2), var(--bg-2) 13px, var(--bg-3) 13px, var(--bg-3) 26px);
      }
      .proj-shot img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: auto;
        display: block;
        transition: transform 3.6s var(--ease);
      }
      .proj-item:hover .proj-shot img.scrollable {
        transform: translateY(calc(-100% + var(--shot-h, 260px)));
      }
      .proj-shot .ph {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted);
      }
      .proj-shot .ph span {
        background: var(--bg);
        padding: 7px 13px;
        border-radius: 999px;
        border: 1px solid var(--line);
      }
      .proj-num {
        position: absolute;
        top: 50px;
        left: 18px;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent-text);
        z-index: 2;
        background: color-mix(in srgb, var(--bg) 70%, transparent);
        padding: 3px 9px;
        border-radius: 999px;
        backdrop-filter: blur(4px);
      }
      .proj-info .kind {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-2);
        letter-spacing: 0.02em;
        display: flex;
        gap: 14px;
        align-items: center;
        margin-bottom: 14px;
      }
      .proj-info .kind .yr { color: var(--muted); }
      .proj-name {
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: 18px;
      }
      .proj-desc {
        color: var(--fg-2);
        line-height: 1.66;
        max-width: 48ch;
        margin-bottom: 22px;
      }
      .tags { display: flex; flex-wrap: wrap; gap: 9px; margin-bottom: 26px; }
      .tag {
        font-family: var(--font-mono);
        font-size: 11.5px;
        color: var(--fg-2);
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 12px;
        transition: border-color 0.25s, color 0.25s;
      }
      .proj-item:hover .tag { border-color: var(--line-2); }
      .proj-links { display: flex; gap: 12px; flex-wrap: wrap; }
      .plink {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-family: var(--font-mono);
        font-size: 13px;
        padding: 11px 18px;
        border-radius: 999px;
        border: 1px solid var(--line-2);
        transition: transform 0.3s var(--ease), background 0.3s, color 0.3s, border-color 0.3s;
      }
      .plink.primary {
        background: var(--accent);
        color: var(--accent-ink);
        border-color: var(--accent);
        font-weight: 700;
      }
      .plink:not(.primary):hover {
        border-color: var(--fg);
        background: color-mix(in srgb, var(--fg) 7%, transparent);
      }
      .plink .arr { transition: transform 0.3s var(--ease); }
      .plink:hover .arr { transform: translate(3px, -3px); }

      /* STACK */
      .stack-note {
        color: var(--fg-2);
        max-width: 40ch;
        margin-bottom: 46px;
        font-size: 1.05rem;
      }
      .stack-groups { display: grid; gap: 0; border-top: 1px solid var(--line); }
      .stack-row {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 30px;
        padding: 30px 0;
        border-bottom: 1px solid var(--line);
        align-items: center;
      }
      .stack-row h3 {
        font-family: var(--font-mono);
        font-size: 13px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--fg-2);
        font-weight: 400;
      }
      .chips { display: flex; flex-wrap: wrap; gap: 12px; }
      .chip {
        font-size: clamp(1.05rem, 1.6vw, 1.35rem);
        font-weight: 500;
        letter-spacing: -0.01em;
        padding: 6px 0;
        color: var(--fg);
        position: relative;
        cursor: default;
        transition: color 0.25s;
      }
      .chip:not(:last-child)::after {
        content: "";
        display: inline-block;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--muted);
        margin-left: 12px;
        vertical-align: middle;
      }
      .chip:hover { color: var(--accent-text); }

      /* CONTACT */
      #contact { padding: clamp(90px, 14vw, 180px) 0; }
      .contact-inner {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .contact-inner .h2 { max-width: 18ch; margin: 0 auto 24px; }
      .contact-sub {
        color: var(--fg-2);
        font-size: clamp(1rem, 1.6vw, 1.2rem);
        max-width: 46ch;
        margin: 0 auto 44px;
        line-height: 1.6;
      }
      .mail-btn {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(1.4rem, 4vw, 2.6rem);
        letter-spacing: -0.03em;
        color: var(--fg);
        display: inline-flex;
        align-items: center;
        gap: 18px;
        border-bottom: 2px solid var(--line);
        padding-bottom: 10px;
        transition: color 0.3s, border-color 0.3s, gap 0.3s var(--ease);
      }
      .mail-btn:hover { color: var(--accent-text); border-color: var(--accent); gap: 26px; }
      .mail-btn .arr { transition: transform 0.35s var(--ease); }
      .mail-btn:hover .arr { transform: translate(6px, -6px); }
      .contact-meta {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 50px;
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--fg-2);
      }
      .contact-meta .it { display: flex; align-items: center; gap: 9px; }
      .contact-meta .it .live {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 8px var(--glow);
      }
      .socials { display: flex; gap: 14px; margin-top: 40px; }
      .soc {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--line);
        display: grid;
        place-items: center;
        transition: border-color 0.3s, transform 0.35s var(--ease), background 0.3s;
      }
      .soc:hover { border-color: var(--accent); transform: translateY(-4px); }
      .soc svg { width: 19px; height: 19px; }

      /* FOOTER */
      footer {
        border-top: 1px solid var(--line);
        padding: 40px var(--pad);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--muted);
      }
      footer .top {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: color 0.25s;
      }
      footer .top:hover { color: var(--accent-text); }

      /* REVEAL — base is visible; only hidden when JS is active (degrades safely) */
      .reveal { opacity: 1; transform: none; }
      html.js .reveal {
        opacity: 0;
        transform: translateY(34px);
        transition: opacity 0.9s var(--ease), transform 0.9s var(--ease);
      }
      html.js .reveal.in { opacity: 1; transform: none; }
      .reveal[data-d="1"] { transition-delay: 0.08s; }
      .reveal[data-d="2"] { transition-delay: 0.16s; }
      .reveal[data-d="3"] { transition-delay: 0.24s; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        * { animation: none !important; }
      }

      /* RESPONSIVE */
      @media (max-width: 920px) {
        .about-grid { grid-template-columns: 1fr; }
        .about-side { position: static; flex-direction: row; flex-wrap: wrap; }
        .portrait { flex: 1; min-width: 200px; aspect-ratio: 1/1; }
        .stats { flex: 1; min-width: 240px; }
        .proj-item { grid-template-columns: 1fr; }
        .proj-item:nth-child(even) .proj-media { order: 0; }
        .stack-row { grid-template-columns: 1fr; gap: 12px; }
        .xp-list { grid-template-columns: 1fr; }
        .xp-card.solo { grid-column: auto; }
      }
      @media (max-width: 720px) {
        .nav-links { display: none; }
        .nav-links.open {
          display: flex;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          background: var(--bg-2);
          border-bottom: 1px solid var(--line);
          padding: 24px var(--pad);
          gap: 20px;
        }
        .burger {
          display: grid;
          place-items: center;
          width: 38px;
          height: 38px;
          border-radius: 50%;
          border: 1px solid var(--line);
          background: transparent;
          color: var(--fg);
          cursor: pointer;
        }
        .burger svg { width: 18px; height: 18px; }
        .hero-bottom { flex-direction: column; align-items: flex-start; }
        .hero-ctas { width: 100%; }
        /* en móvil el contenido del hero crece (botones apilados): ocultamos
           el indicador "Desliza" para que no se solape con los CTAs */
        .scrollcue { display: none; }
        .contact-meta { gap: 18px; }
        .ck { left: 12px; right: 12px; bottom: 12px; width: auto; }
      }

      /* ============================================================
         COOKIE CONSENT
         ============================================================ */
      .ck {
        position: fixed;
        right: 22px;
        bottom: 22px;
        z-index: 250;
        width: min(420px, calc(100vw - 44px));
        animation: ckIn 0.5s var(--ease) both;
      }
      .ck[hidden] { display: none; }
      @keyframes ckIn {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: none; }
      }
      .ck-card {
        background: color-mix(in srgb, var(--bg-2) 88%, transparent);
        backdrop-filter: blur(16px) saturate(140%);
        -webkit-backdrop-filter: blur(16px) saturate(140%);
        border: 1px solid var(--line-2);
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.6);
      }
      .ck-title {
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }
      .ck-text {
        color: var(--fg-2);
        font-size: 0.9rem;
        line-height: 1.55;
      }
      .ck-policy {
        display: inline-block;
        margin-top: 10px;
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent-text);
        border-bottom: 1px solid currentColor;
        padding-bottom: 1px;
      }
      .ck-prefs {
        margin-top: 16px;
        border-top: 1px solid var(--line);
        padding-top: 6px;
      }
      .ck-prefs[hidden] { display: none; }
      .ck-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 0;
        border-bottom: 1px solid var(--line);
      }
      .ck-row:last-child { border-bottom: 0; }
      .ck-row-t { display: block; font-weight: 600; font-size: 0.92rem; }
      .ck-row-d { display: block; color: var(--muted); font-size: 0.8rem; line-height: 1.45; margin-top: 3px; }
      .ck-always {
        font-family: var(--font-mono);
        font-size: 10.5px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        white-space: nowrap;
        flex-shrink: 0;
      }
      /* toggle */
      .ck-switch {
        appearance: none;
        -webkit-appearance: none;
        width: 42px;
        height: 24px;
        border-radius: 999px;
        background: var(--line-2);
        position: relative;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.3s var(--ease);
      }
      .ck-switch::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--fg);
        transition: transform 0.3s var(--ease);
      }
      .ck-switch:checked { background: var(--accent); }
      .ck-switch:checked::after { transform: translateX(18px); background: var(--accent-ink); }
      .ck-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }
      .ck-btn {
        flex: 1;
        min-width: 92px;
        font-family: var(--font-mono);
        font-size: 12.5px;
        padding: 11px 14px;
        border-radius: 999px;
        cursor: pointer;
        border: 1px solid var(--line-2);
        background: transparent;
        color: var(--fg);
        transition: border-color 0.25s, background 0.25s, color 0.25s, transform 0.25s var(--ease);
      }
      .ck-btn[hidden] { display: none; }
      .ck-ghost:hover {
        border-color: var(--fg);
        background: color-mix(in srgb, var(--fg) 7%, transparent);
      }
      .ck-primary {
        background: var(--accent);
        color: var(--accent-ink);
        border-color: var(--accent);
        font-weight: 700;
      }
      .ck-primary:hover { box-shadow: 0 12px 30px -10px var(--glow); }

      /* enlace "Cookies" del footer */
      footer .ck-open {
        cursor: pointer;
        transition: color 0.25s;
        background: none;
        border: 0;
        color: inherit;
        font: inherit;
      }
      footer .ck-open:hover { color: var(--accent-text); }

      /* ============================================================
         COOKIE POLICY PAGE
         ============================================================ */
      .legal { padding: clamp(120px, 16vw, 200px) 0 clamp(70px, 10vw, 120px); }
      .legal .updated {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted);
        margin: 14px 0 34px;
      }
      .legal .intro { color: var(--fg-2); font-size: 1.05rem; line-height: 1.7; max-width: 70ch; }
      .legal h2 {
        font-size: clamp(1.2rem, 2.4vw, 1.6rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 44px 0 14px;
      }
      .legal p { color: var(--fg-2); line-height: 1.72; max-width: 72ch; }
      .legal a { color: var(--accent-text); border-bottom: 1px solid currentColor; }
      .legal .ck-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 18px;
        font-size: 0.9rem;
      }
      .legal .ck-table th,
      .legal .ck-table td {
        text-align: left;
        padding: 13px 14px;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }
      .legal .ck-table th {
        font-family: var(--font-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--fg-2);
        font-weight: 400;
      }
      .legal .ck-table td:first-child {
        font-family: var(--font-mono);
        color: var(--accent-text);
        white-space: nowrap;
      }
      .legal .ck-table tr:hover td { background: color-mix(in srgb, var(--fg) 3%, transparent); }
      @media (max-width: 620px) {
        .legal .ck-table, .legal .ck-table tbody, .legal .ck-table tr, .legal .ck-table td { display: block; }
        .legal .ck-table thead { display: none; }
        .legal .ck-table tr {
          border: 1px solid var(--line);
          border-radius: 12px;
          padding: 8px 12px;
          margin-bottom: 12px;
        }
        .legal .ck-table td { border-bottom: 0; padding: 5px 0; }
      }
    </style>
  </body>
</html>
